{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",

    "module": "nodenext",
    "target": "esnext",
    "types": ["node"],

    "sourceMap": true,

    "strict": true,
    "skipLibCheck": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src", "types"]
}